---
// Öffentliche Seite – wird beim Build aus public/passages/ statisch erzeugt.
import { promises as fs } from 'node:fs';
import path from 'node:path';

const CANVAS_W = 2560, CANVAS_H = 1440;
const IMG_EXT = new Set(['.jpg', '.jpeg', '.png', '.webp', '.gif']);
const passagesDir = path.join(process.cwd(), 'public', 'passages');

async function readPassages() {
  let entries = [];
  try { entries = await fs.readdir(passagesDir, { withFileTypes: true }); } catch { return []; }
  const present = entries.filter(e => e.isDirectory()).map(e => e.name);
  const presentSet = new Set(present);
  let order = [];
  try { order = JSON.parse(await fs.readFile(path.join(passagesDir, '_order.json'), 'utf8')); } catch {}
  const dirs = order.filter(id => presentSet.has(id));
  for (const id of present.sort()) if (!dirs.includes(id)) dirs.push(id);
  const out = [];
  for (const id of dirs) {
    let meta = null;
    try { meta = JSON.parse(await fs.readFile(path.join(passagesDir, id, 'passage.json'), 'utf8')); } catch {}
    let hasDrawing = false;
    try { await fs.access(path.join(passagesDir, id, 'drawing.png')); hasDrawing = true; } catch {}
    out.push({ id, images: (meta && meta.images) || [], updated: (meta && meta.updated) || '', hasDrawing });
  }
  return out;
}
const passages = await readPassages();
const pct = (v, total) => (v / total * 100) + '%';
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Fotowebsite</title>
  <link rel="stylesheet" href="viewer.css" />
</head>
<body>
  {passages.length === 0 && <div class="empty">Noch keine Passagen.</div>}
  <div class="stack">
    {passages.map((p, i) => (
      <section class="passage" id={p.id} style={`z-index:${i + 1}`}>
        <div class="stage">
          {p.images.map((im) => (
            <img
              class="layer-img"
              src={`passages/${p.id}/${im.src}`}
              style={`left:${pct(im.x, CANVAS_W)};top:${pct(im.y, CANVAS_H)};width:${pct(im.w, CANVAS_W)};height:${pct(im.h, CANVAS_H)}`}
              alt=""
            />
          ))}
          {p.hasDrawing && <img class="drawing" src={`passages/${p.id}/drawing.png?v=${p.updated}`} alt="" />}
        </div>
      </section>
    ))}
  </div>
  {passages.length > 1 && <div class="scroll-hint">↑ hochschieben</div>}
  <script is:inline src="viewer.js"></script>
</body>
</html>
